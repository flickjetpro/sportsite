---
import MatchLayout from '../../layouts/MatchLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Countdown from '../../components/Countdown.astro';
import { mapToPremiumSport } from '../../lib/api';
import { formatET, formatETWithDate, getMatchStatus } from '../../lib/time';
import { getMatchSEO } from '../../lib/seo';
import { STREAM_DOMAIN, SOURCE_NAMES, formatStreamLabel } from '../../lib/config';
import type { APIMatch } from '../../lib/api';
import sportsData from '../../data/sports.json';

export async function getStaticPaths() {
  const liveFile = import.meta.glob('../../data/matches-live.json', { eager: true });
  const todayFile = import.meta.glob('../../data/matches-today.json', { eager: true });
  const liveData: APIMatch[] = (Object.values(liveFile)[0] as any)?.default || [];
  const todayData: APIMatch[] = (Object.values(todayFile)[0] as any)?.default || [];
  const allMatches = [...liveData, ...todayData];
  return allMatches.map((m) => ({
    params: { id: m.id },
    props: { match: m },
  }));
}

const { match } = Astro.props as { match: APIMatch };
const premiumMatch = mapToPremiumSport(match);
const status = match._liveSource ? 'live' : getMatchStatus(match);
const statusColors: Record<string, string> = {
  live: 'text-buff-live',
  upcoming: 'text-buff-gold',
  finished: 'text-buff-muted',
};
const statusLabels: Record<string, string> = {
  live: 'LIVE',
  upcoming: 'UPCOMING',
  finished: 'FINAL',
};
const sportConfig = premiumMatch.premiumSport
  ? (sportsData.premiumSports as Record<string, any>)[premiumMatch.premiumSport]
  : null;
const sources = match.sources || [];
const sourceName = (s: string) => SOURCE_NAMES[s] || s.charAt(0).toUpperCase() + s.slice(1);
---

<MatchLayout match={premiumMatch}>
  <div slot="breadcrumb">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      ...(sportConfig ? [{ name: sportConfig.displayName, url: `/${premiumMatch.premiumSport}` }] : []),
      { name: match.title, url: `/match/${match.id}` },
    ]} />
  </div>
  <div slot="content">
    <div class="flex flex-col items-center gap-4 py-8 text-center">
      {match.teams?.home?.name || match.teams?.away?.name ? (
        <div class="flex items-center gap-6">
          {match.teams?.home?.name && (
            <div class="flex flex-col items-center gap-2">
              {match.teams.home.badge && (
                <img
                  src={`/api/proxy/images/badge/${match.teams.home.badge}.webp`}
                  alt={match.teams.home.name}
                  class="h-16 w-16 rounded-full object-contain"
                />
              )}
              <span class="text-sm font-medium text-white">{match.teams.home.name}</span>
            </div>
          )}
          <span class="text-2xl font-bold text-buff-muted">VS</span>
          {match.teams?.away?.name && (
            <div class="flex flex-col items-center gap-2">
              {match.teams.away.badge && (
                <img
                  src={`/api/proxy/images/badge/${match.teams.away.badge}.webp`}
                  alt={match.teams.away.name}
                  class="h-16 w-16 rounded-full object-contain"
                />
              )}
              <span class="text-sm font-medium text-white">{match.teams.away.name}</span>
            </div>
          )}
        </div>
      ) : null}

      <h1 class="mt-4 text-xl font-bold text-white">{match.title}</h1>

      <div class="flex flex-wrap items-center justify-center gap-3 text-sm">
        {premiumMatch.categoryBadge && (
          <span class="rounded bg-buff-card px-2 py-0.5 text-xs font-bold text-buff-gold">
            {premiumMatch.categoryBadge}
          </span>
        )}
        <span class="text-buff-muted">{formatETWithDate(match.date)}</span>
        <span class="font-mono text-white">{formatET(match.date)} ET</span>
        <span class={`font-bold ${statusColors[status]}`}>
          {statusLabels[status]}
        </span>
      </div>

      {status !== 'finished' && (
        <Countdown matchDate={match.date} />
      )}
    </div>

    {sources.length > 0 && (
      <section class="mt-8">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-lg font-bold text-white">Stream Links</h2>
          <span class="text-sm text-buff-muted" id="stream-count">Loading...</span>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" id="stream-grid">
          {sources.map((s) => {
            const name = sourceName(s.source);
            return (
              <a
                href={`https://${STREAM_DOMAIN}/match/${match.id}?source=${s.source}`}
                target="_blank"
                rel="noopener noreferrer"
                data-source={s.source}
                data-sid={s.id}
                class="stream-card group flex flex-col gap-1 rounded-lg border border-buff-border bg-buff-card p-4 no-underline transition hover:border-buff-gold"
              >
                <div class="flex items-center justify-between">
                  <span class="text-sm font-bold text-buff-gold">{name}</span>
                </div>
                <span class="text-xs text-buff-muted">Loading streams...</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {sources.length === 0 && (
      <section class="mt-8 text-center">
        <p class="rounded-lg border border-buff-border bg-buff-card px-6 py-8 text-sm text-buff-muted">
          No stream sources available yet. Check back closer to game time.
        </p>
      </section>
    )}

    <div class="mt-12">
      <article class="prose prose-invert max-w-none">
        <p class="text-buff-muted">{getMatchSEO(match)}</p>
      </article>
    </div>

    <script is:inline set:html={`(function () {
    var matchId = ${JSON.stringify(match.id)};
    var sources = ${JSON.stringify(sources)};
    var sourceNames = ${JSON.stringify(SOURCE_NAMES)};
    var streamDomain = ${JSON.stringify(STREAM_DOMAIN)};
    var grid = document.getElementById('stream-grid');
    var countEl = document.getElementById('stream-count');
    if (!grid) return;

    function sourceLabel(source) {
      return sourceNames[source] || source.charAt(0).toUpperCase() + source.slice(1);
    }

    function escapeHtml(text) {
      var d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    async function loadStreams() {
      var allStreams = [];

      for (var i = 0; i < sources.length; i++) {
        var src = sources[i];
        try {
          var res = await fetch('/api/proxy/stream/' + src.source + '/' + src.id);
          var data2 = await res.json();
          var list = Array.isArray(data2) ? data2 : (data2.value || []);
          for (var j = 0; j < list.length; j++) {
            var s = list[j];
            allStreams.push({
              source: src.source,
              streamNo: s.streamNo || 1,
              language: s.language || '',
              hd: s.hd === true,
              embedUrl: s.embedUrl || '',
              viewers: s.viewers || 0,
            });
          }
        } catch (e) {}
      }

      if (allStreams.length === 0) {
        var cards = grid.querySelectorAll('.stream-card');
        for (var k = 0; k < cards.length; k++) {
          var desc = cards[k].querySelector('.text-xs');
          if (desc) desc.textContent = 'No streams available';
        }
        if (countEl) countEl.textContent = '0 streams';
        return;
      }

      if (countEl) countEl.textContent = allStreams.length + ' ' + (allStreams.length === 1 ? 'stream' : 'streams') + ' available';

      grid.innerHTML = '';

      for (var m = 0; m < allStreams.length; m++) {
        var s2 = allStreams[m];
        var label = sourceLabel(s2.source) + ' #' + s2.streamNo;
        var quality = s2.hd ? 'HD' : 'SD';
        var lang = s2.language;
        var href = 'https://' + streamDomain + '/match/' + matchId + '?source=' + s2.source + '&stream=' + s2.streamNo;

        var card = document.createElement('a');
        card.href = href;
        card.target = '_blank';
        card.rel = 'noopener noreferrer';
        card.className = 'group flex flex-col gap-1.5 rounded-lg border border-buff-border bg-buff-card p-4 no-underline transition hover:border-buff-gold';

        var badges = '';
        badges += '<span class="inline-block rounded bg-buff-dark px-1.5 py-0.5 text-xs font-bold ' + (quality === 'HD' ? 'text-buff-gold' : 'text-buff-muted') + '">' + quality + '</span>';
        if (lang) {
          badges += '<span class="inline-block rounded bg-buff-dark px-1.5 py-0.5 text-xs text-buff-muted">' + escapeHtml(lang) + '</span>';
        }

        var viewersHtml = '';
        if (s2.viewers > 0) {
          viewersHtml = '<span class="text-xs font-semibold" style="color:#22c55e">' + s2.viewers.toLocaleString() + ' watching</span>';
        } else {
          viewersHtml = '<span class="text-xs text-buff-muted">0 watching</span>';
        }

        card.innerHTML = '<div class="flex items-center justify-between"><span class="text-sm font-bold text-buff-gold">' + escapeHtml(label) + '</span><div class="flex gap-1">' + badges + '</div></div><div class="flex items-center justify-between"><span class="text-xs text-buff-muted">' + escapeHtml(s2.source) + '</span>' + viewersHtml + '</div>';
        grid.appendChild(card);
      }
    }

    loadStreams();
  })();`}>
    </script>
  </div>
</MatchLayout>
