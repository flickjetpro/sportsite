---
import MatchLayout from '../../layouts/MatchLayout.astro';
import MatchArticle from '../../components/MatchArticle.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Countdown from '../../components/Countdown.astro';
import { mapToPremiumSport } from '../../lib/api';
import { formatET, formatETWithDate } from '../../lib/time';
import { getMatchSEO } from '../../lib/seo';
import { SOURCE_NAMES, formatStreamLabel } from '../../lib/config';
import { slugifyTeam } from '../../lib/images';
import type { APIMatch } from '../../lib/api';
import sportsData from '../../data/sports.json';

export async function getStaticPaths() {
  const liveFile = import.meta.glob('../../data/matches-live.json', { eager: true });
  const todayFile = import.meta.glob('../../data/matches-today.json', { eager: true });
  const liveData: APIMatch[] = (Object.values(liveFile)[0] as any)?.default || [];
  const todayData: APIMatch[] = (Object.values(todayFile)[0] as any)?.default || [];
  const allMap = new Map<string, APIMatch>();
  for (const m of liveData) allMap.set(m.id, m);
  for (const m of todayData) if (!allMap.has(m.id)) allMap.set(m.id, m);
  const allMatches = [...allMap.values()];
  return allMatches.map((m) => ({
    params: { id: m.id },
    props: { match: m },
  }));
}

const { match } = Astro.props as { match: APIMatch };
const premiumMatch = mapToPremiumSport(match);
const status = Date.now() < match.date ? 'upcoming' : 'live';
const statusColors: Record<string, string> = {
  live: 'text-buff-live',
  upcoming: 'text-buff-gold',
  finished: 'text-buff-muted',
};
const statusLabels: Record<string, string> = {
  live: 'LIVE',
  upcoming: 'UPCOMING',
  finished: 'FINAL',
};
const sportConfig = premiumMatch.premiumSport
  ? (sportsData.premiumSports as Record<string, any>)[premiumMatch.premiumSport]
  : null;
const sources = match.sources || [];
const sourceName = (s: string) => SOURCE_NAMES[s] || s.charAt(0).toUpperCase() + s.slice(1);
---

<MatchLayout match={premiumMatch}>
  <div slot="breadcrumb">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      ...(sportConfig ? [{ name: sportConfig.displayName, url: `/${premiumMatch.premiumSport}` }] : []),
      { name: match.title, url: `/match/${match.id}` },
    ]} />
  </div>
  <div slot="content">
    <div class="flex flex-col items-center gap-4 py-8 text-center">
      {match.teams?.home?.name || match.teams?.away?.name ? (
        <div class="flex items-center gap-6">
              {match.teams?.home?.name && (
            <div class="flex flex-col items-center gap-2">
              <img
                src={`/badges/${slugifyTeam(match.teams.home.name)}.webp`}
                alt={match.teams.home.name}
                class="h-16 w-16 rounded-full object-contain"
              />
              <span class="text-sm font-medium text-white">{match.teams.home.name}</span>
            </div>
          )}
          <span class="text-2xl font-bold text-buff-muted">VS</span>
          {match.teams?.away?.name && (
            <div class="flex flex-col items-center gap-2">
              <img
                src={`/badges/${slugifyTeam(match.teams.away.name)}.webp`}
                alt={match.teams.away.name}
                class="h-16 w-16 rounded-full object-contain"
              />
              <span class="text-sm font-medium text-white">{match.teams.away.name}</span>
            </div>
          )}
        </div>
      ) : null}

      <h1 class="mt-4 text-xl font-bold text-white">{match.title}</h1>

      <div class="flex flex-wrap items-center justify-center gap-3 text-sm">
        {premiumMatch.categoryBadge && (
          <span class="rounded bg-buff-card px-2 py-0.5 text-xs font-bold text-buff-gold">
            {premiumMatch.categoryBadge}
          </span>
        )}
        <span class="text-buff-muted">{formatETWithDate(match.date)}</span>
        <span class="font-mono text-white">{formatET(match.date)} ET</span>
        <span class={`font-bold ${statusColors[status]}`}>
          {statusLabels[status]}
        </span>
      </div>

      {status === 'upcoming' && (
        <Countdown matchDate={match.date} />
      )}
    </div>

    <!-- Main site banner ad -->
    <div class="mx-auto mb-6 flex justify-center overflow-hidden" style="min-height: 90px;">
      <script is:inline>
        window.atOptions = {
          'key' : '241db7bdcb4b8a8b1ec2148fa3758b17',
          'format' : 'iframe',
          'height' : 90,
          'width' : 728,
          'params' : {}
        };
      </script>
      <script is:inline src="https://www.highperformanceformat.com/241db7bdcb4b8a8b1ec2148fa3758b17/invoke.js"></script>
    </div>

    {sources.length > 0 && (
      <section class="mt-8">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-lg font-bold text-white">Stream Links</h2>
          <span class="text-sm text-buff-muted" id="stream-count">Loading...</span>
        </div>
        <div id="stream-grid" class="flex flex-col gap-4"></div>
      </section>
    )}

    {sources.length === 0 && (
      <section class="mt-8 text-center">
        <p class="rounded-lg border border-buff-border bg-buff-card px-6 py-8 text-sm text-buff-muted">
          No stream sources available yet. Check back closer to game time.
        </p>
      </section>
    )}

    <div class="mt-12">
      <MatchArticle match={premiumMatch} />
    </div>

    <script is:inline set:html={`(function () {
    var matchId = ${JSON.stringify(match.id)};
    var sources = ${JSON.stringify(sources)};
    var sourceNames = ${JSON.stringify(SOURCE_NAMES)};
    var grid = document.getElementById('stream-grid');
    var countEl = document.getElementById('stream-count');
    if (!grid) return;

    function sourceLabel(source) {
      return sourceNames[source] || source.charAt(0).toUpperCase() + source.slice(1);
    }

    function escapeHtml(text) {
      var d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    async function loadStreams() {
      var allStreams = [];

      for (var i = 0; i < sources.length; i++) {
        var src = sources[i];
        try {
          var res = await fetch('https://streamed.pk/api/stream/' + src.source + '/' + src.id);
          var data2 = await res.json();
          var list = Array.isArray(data2) ? data2 : (data2.value || []);
          for (var j = 0; j < list.length; j++) {
            var s = list[j];
            allStreams.push({
              source: src.source,
              streamNo: s.streamNo || 1,
              language: s.language || '',
              hd: s.hd === true,
              embedUrl: s.embedUrl || '',
              viewers: s.viewers || 0,
            });
          }
        } catch (e) {}
      }

      if (allStreams.length === 0) {
        grid.innerHTML = '<div class="rounded-lg border border-buff-border bg-buff-card px-6 py-8 text-center text-sm text-buff-muted">No streams available</div>';
        if (countEl) countEl.textContent = '0 streams';
        return;
      }

      if (countEl) countEl.textContent = allStreams.length + ' ' + (allStreams.length === 1 ? 'stream' : 'streams') + ' available';

      // Group by source
      var sourceGroups = {};
      for (var i = 0; i < allStreams.length; i++) {
        var s = allStreams[i];
        if (!sourceGroups[s.source]) sourceGroups[s.source] = [];
        sourceGroups[s.source].push(s);
      }

      grid.innerHTML = '';

      var sourceKeys = Object.keys(sourceGroups);
      for (var si = 0; si < sourceKeys.length; si++) {
        var srcName = sourceKeys[si];
        var streams = sourceGroups[srcName];

        var section = document.createElement('div');
        section.className = 'rounded-lg border border-buff-border bg-buff-darker';

        // Header
        var header = document.createElement('div');
        header.className = 'flex items-center justify-between border-b border-buff-border px-4 py-3';
        header.innerHTML = '<span class="text-sm font-bold text-buff-gold">' + escapeHtml(sourceLabel(srcName)) + '</span>' +
          '<span class="text-xs text-buff-muted">' + streams.length + ' ' + (streams.length === 1 ? 'stream' : 'streams') + '</span>';
        section.appendChild(header);

        // Rows
        for (var ri = 0; ri < streams.length; ri++) {
          var st = streams[ri];
          var isLast = ri === streams.length - 1;
          var href = 'https://watch.buffstreamsbackup.world/?id=' + matchId + '&source=' + st.source + '&stream=' + st.streamNo;
          var quality = st.hd ? 'HD' : 'SD';
          var qClass = st.hd ? 'text-buff-gold' : 'text-buff-muted';
          var viewersColor = st.viewers > 0 ? 'color:#22c55e' : 'color:#888';
          var viewersText = st.viewers > 0 ? st.viewers.toLocaleString() + ' watching' : '0 watching';

          var row = document.createElement('a');
          row.href = href;
          row.target = '_blank';
          row.rel = 'noopener noreferrer';
          row.className = 'relative flex items-center gap-3 bg-buff-card p-3 no-underline transition hover:bg-buff-hover' +
            (isLast ? '' : ' border-b border-buff-border/50');

          row.innerHTML =
            '<span class="min-w-0 flex-1 text-sm font-medium text-white">' + escapeHtml(st.language || 'Unknown') + '</span>' +
            '<span class="inline-block rounded bg-buff-dark px-1.5 py-0.5 text-xs font-bold ' + qClass + '">' + quality + '</span>' +
            '<span class="text-xs font-semibold" style="' + viewersColor + '">' + viewersText + '</span>' +
            '<span class="ml-1 text-buff-muted">&rsaquo;</span>';

          section.appendChild(row);
        }

        grid.appendChild(section);
      }
    }

    loadStreams();
  })();`}>
    </script>
  </div>
</MatchLayout>
