---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PopularLiveSection from '../components/PopularLiveSection.astro';
import ScheduleSection from '../components/ScheduleSection.astro';
import OtherMatches from '../components/OtherMatches.astro';
import Calendar from '../components/Calendar.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import Footer from '../components/Footer.astro';
import { loadMatchesFromData, filterByDate } from '../lib/api';
import type { APIMatch } from '../lib/api';
import { formatDateParam } from '../lib/time';

const liveFile = import.meta.glob('../data/matches-live.json', { eager: true });
const todayFile = import.meta.glob('../data/matches-today.json', { eager: true });
const liveData: APIMatch[] = (Object.values(liveFile)[0] as any)?.default || [];
const todayData: APIMatch[] = (Object.values(todayFile)[0] as any)?.default || [];

const allMatches = loadMatchesFromData([...liveData, ...todayData]);
const liveMatches = loadMatchesFromData(liveData);
const now = Date.now();
const todayStr = formatDateParam(now);
const filteredMatches = filterByDate(allMatches, todayStr);
const scheduleMatches = filteredMatches.filter((m) => m.date > now);
---

<Base title="Full Sports Schedule | Buffstreams Backup" description="Browse the complete sports schedule for today. Find NFL, NBA, MLB, NHL, UFC, and more game times.">
  <Header />
  <main class="mx-auto max-w-7xl px-4 py-6">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Schedule', url: '/schedule' },
    ]} />
    <h1 class="mb-6 text-2xl font-bold text-white">Today's Schedule</h1>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <PopularLiveSection allMatches={liveMatches} initialShow={15} step={15} viewAllMode="inline" />
        <div class="mt-6">
          <ScheduleSection matches={scheduleMatches} heading="TODAY'S STREAM LINKS" />
        </div>
        <div class="mt-6">
          <OtherMatches matches={scheduleMatches} />
        </div>
      </div>
      <div class="lg:col-span-1">
        <Calendar />
        <div class="mt-6">
          <BlogSidebar />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
