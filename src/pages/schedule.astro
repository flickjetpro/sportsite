---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import MatchCard from '../components/MatchCard.astro';
import ScheduleSection from '../components/ScheduleSection.astro';
import OtherMatches from '../components/OtherMatches.astro';
import Calendar from '../components/Calendar.astro';
import Footer from '../components/Footer.astro';
import { loadMatchesFromData, filterByDate } from '../lib/api';
import type { APIMatch } from '../lib/api';
import { formatDateParam } from '../lib/time';

const liveFile = import.meta.glob('../data/matches-live.json', { eager: true });
const todayFile = import.meta.glob('../data/matches-today.json', { eager: true });
const liveData: APIMatch[] = (Object.values(liveFile)[0] as any)?.default || [];
const todayData: APIMatch[] = (Object.values(todayFile)[0] as any)?.default || [];

const allMatches = loadMatchesFromData([...liveData, ...todayData]);
const dateParam = Astro.url.searchParams.get('date') || '';
const now = Date.now();
const todayStr = formatDateParam(now);
const filteredMatches = dateParam ? filterByDate(allMatches, dateParam) : filterByDate(allMatches, todayStr);

// Check if viewing today
const isToday = dateParam ? dateParam === todayStr : true;

// Split into live (within 3h window) and upcoming
const liveMatches = isToday ? filteredMatches.filter((m) => {
  const end = m.date + 3 * 60 * 60 * 1000;
  return now >= m.date && now <= end;
}) : [];

const scheduleMatches = isToday ? filteredMatches.filter((m) => m.date > now) : filteredMatches;

// Order live: popular first, then non-popular
const orderedLive = [...liveMatches.filter(m => m.popular), ...liveMatches.filter(m => !m.popular)];
---

<Base title="Full Sports Schedule | Buffstreams Backup" description="Browse the complete sports schedule for today. Find NFL, NBA, MLB, NHL, UFC, and more game times.">
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-6">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Schedule', url: '/schedule' },
    ]} />
    <h1 class="mb-6 text-2xl font-bold text-white">
      {dateParam ? `Schedule for ${dateParam}` : "Today's Schedule"}
    </h1>

    {isToday && orderedLive.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-buff-live">
          <span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live" />
          LIVE NOW
        </h2>
        <div class="flex flex-col gap-2">
          {orderedLive.map((m) => (
            <MatchCard match={m} showCategoryBadge={true} />
          ))}
        </div>
      </section>
    )}

    <ScheduleSection matches={scheduleMatches} heading="SCHEDULE" />
    <div class="mt-8">
      <OtherMatches matches={scheduleMatches} />
    </div>
    <div class="mt-8">
      <Calendar />
    </div>
  </main>
  <Footer />
</Base>

<script>
  (function() {
    var params = new URLSearchParams(window.location.search);
    var dateParam = params.get('date');
    if (dateParam) {
      var heading = document.querySelector('h1');
      if (heading) heading.textContent = 'Schedule for ' + dateParam;
      var cards = document.querySelectorAll('[data-date-str]');
      cards.forEach(function(card) {
        if (card.getAttribute('data-date-str') !== dateParam) {
          card.style.display = 'none';
        }
      });
    }
  })();
</script>
