---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HomepageArticle from '../components/HomepageArticle.astro';
import Footer from '../components/Footer.astro';
---

<Base title="FAQ - Frequently Asked Questions | Buffstreams" description="Frequently asked questions about Buffstreams sports schedule directory.">
  <Header />
  <main class="mx-auto max-w-5xl px-2 py-6 sm:px-4">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'FAQ', url: '/faq' },
    ]} />
    <h1 class="mb-6 text-2xl font-bold text-white">Frequently Asked Questions</h1>
    <HomepageArticle />
  </main>
  <Footer />
</Base>
