---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PopularLiveSection from '../../components/PopularLiveSection.astro';
import ScheduleSection from '../../components/ScheduleSection.astro';
import OtherMatches from '../../components/OtherMatches.astro';
import Calendar from '../../components/Calendar.astro';
import BlogSidebar from '../../components/BlogSidebar.astro';
import Footer from '../../components/Footer.astro';
import { loadMatchesFromData, filterByDate } from '../../lib/api';
import { formatDateParam } from '../../lib/time';
import type { APIMatch } from '../../lib/api';
import datesData from '../../data/dates.json';

export async function getStaticPaths() {
  return (datesData as string[]).map((date) => ({
    params: { date },
    props: { date },
  }));
}

const { date } = Astro.props as { date: string };

const liveFile = import.meta.glob('../../data/matches-live.json', { eager: true });
const todayFile = import.meta.glob('../../data/matches-today.json', { eager: true });
const liveData: APIMatch[] = (Object.values(liveFile)[0] as any)?.default || [];
const todayData: APIMatch[] = (Object.values(todayFile)[0] as any)?.default || [];

const dedupMap = new Map<string, APIMatch>();
for (const m of [...todayData, ...liveData]) {
  if (m.id && !dedupMap.has(m.id)) dedupMap.set(m.id, m);
}
const allMatches = loadMatchesFromData([...dedupMap.values()]);
const liveMatches = loadMatchesFromData(liveData);
const filteredMatches = filterByDate(allMatches, date);
const now = Date.now();
const todayStr = formatDateParam(now);
const isToday = date === todayStr;

const scheduleMatches = isToday ? filteredMatches.filter((m) => m.date > now) : filteredMatches;
---

<Base title={`Sports Schedule for ${date} | Buffstreams`} description={`Browse the sports schedule for ${date}. Find NFL, NBA, MLB, NHL, UFC, and more game times.`}>
  <Header />
  <main class="mx-auto max-w-7xl px-2 py-6 sm:px-4">
    <Breadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Schedule', url: '/schedule' },
      { name: date, url: `/schedule/${date}` },
    ]} />
    <h1 class="mb-6 text-2xl font-bold text-white">Schedule for {date}</h1>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      <div class="lg:col-span-2">
        {isToday && (
          <PopularLiveSection allMatches={liveMatches} initialShow={15} step={15} viewAllMode="inline" />
        )}
        <div class={isToday ? 'mt-6' : ''}>
          <ScheduleSection matches={scheduleMatches} heading="STREAM LINKS" />
        </div>
        <div class="mt-6">
          <OtherMatches matches={scheduleMatches} />
        </div>
      </div>
      <div class="lg:col-span-1">
        <Calendar activeDate={date} />
        <div class="mt-6">
          <BlogSidebar />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
