---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import SportGrid from '../components/SportGrid.astro';
import PopularLiveSection from '../components/PopularLiveSection.astro';
import ScheduleSection from '../components/ScheduleSection.astro';
import OtherMatches from '../components/OtherMatches.astro';
import Calendar from '../components/Calendar.astro';
import HomepageArticle from '../components/HomepageArticle.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import Footer from '../components/Footer.astro';
import { loadMatchesFromData } from '../lib/api';
import type { APIMatch } from '../lib/api';
import { formatDateParam, getMatchDateStr } from '../lib/time';

const liveFile = import.meta.glob('../data/matches-live.json', { eager: true });
const todayFile = import.meta.glob('../data/matches-today.json', { eager: true });
const liveData: APIMatch[] = (Object.values(liveFile)[0] as any)?.default || [];
const todayData: APIMatch[] = (Object.values(todayFile)[0] as any)?.default || [];

const allMatches = loadMatchesFromData([...liveData, ...todayData]);
const liveIds = new Set(allMatches.filter((m) => m._liveSource).map((m) => m.id));
const now = Date.now();
const todayStr = formatDateParam(now);
const scheduleMatches = allMatches.filter((m) => !liveIds.has(m.id) && m.date > now && m.date <= now + 24 * 60 * 60 * 1000);
const futureMatches = allMatches.filter((m) => !liveIds.has(m.id) && m.date > now && getMatchDateStr(m) !== todayStr);
const todayNonLive = allMatches.filter((m) => !liveIds.has(m.id) && getMatchDateStr(m) === todayStr);
const futureSportNames = new Set<string>();
for (const m of futureMatches) {
  if (m.premiumSport !== null && m.premiumDisplayName) {
    futureSportNames.add(m.premiumDisplayName);
  }
}
---

<Base
  title="Buffstreams - Live sports streaming NFL, NBA, MLB, UFC, Soccer, F1, WWE, & More."
  description="Buffstreams delivers free live sports streaming for NFL, NBA, MLB, NHL, UFC, Soccer, F1, WWE, Boxing, MMA, Tennis, Golf, and NCAA. Watch HD streams of every major league and event without subscription or registration."
>
  <Header />
  <main class="mx-auto max-w-7xl px-2 py-6 sm:px-4">
    <SportGrid />
    <div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <PopularLiveSection initialShow={5} step={5} viewAllMode="link" />
        <div class="mt-6">
          <ScheduleSection matches={scheduleMatches} heading="UPCOMING STREAM LINKS" sportsWithFuture={futureSportNames} />
        </div>
        <div class="mt-6">
          <OtherMatches matches={todayNonLive} />
        </div>
        <div class="mt-6">
          <HomepageArticle />
        </div>
      </div>
      <div class="lg:col-span-1">
        <Calendar />
        <div class="mt-6">
          <BlogSidebar />
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
