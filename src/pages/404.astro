---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found - Buffstreams" description="The page you are looking for is no longer available.">
  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-4xl font-bold text-white">404</h1>
    <p class="mt-4 text-lg text-buff-muted">This match is no longer available.</p>
    <p class="mt-2 text-sm text-buff-muted">Redirecting to schedule...</p>
    <a href="/schedule" class="mt-6 rounded-lg bg-buff-gold px-6 py-3 font-bold text-black no-underline transition hover:opacity-90">
      View Schedule
    </a>
  </main>
  <script>
    setTimeout(function() { window.location.href = '/schedule'; }, 5000);
  </script>
</Base>
