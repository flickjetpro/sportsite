---
import type { PremiumMatch } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  allMatches: PremiumMatch[];
  initialShow: number;
  step: number;
  viewAllMode: 'link' | 'inline';
}

const { allMatches, initialShow, step, viewAllMode } = Astro.props;
const total = allMatches.length;
const remaining = total - initialShow;
---

{total > 0 && (
  <section id="popular-live-section" class="rounded-lg border border-buff-border bg-buff-darker p-4">
    <h2 id="pl-heading" class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
      <span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live" />
      LIVE NOW
    </h2>

    <div class="flex flex-col divide-y divide-dashed divide-buff-border" id="popular-live-grid" data-pl-step={step} data-api="https://stream.alphastreams.fit/api/stream">
      {allMatches.map((m, i) => (
        <div class={i >= initialShow ? 'pl-hidden' : ''} data-pl-index={i} data-sources={encodeURIComponent(JSON.stringify(m.sources || []))}>
          <MatchCard match={m} showCategoryBadge={true} />
        </div>
      ))}
    </div>

    {viewAllMode === 'link' && remaining > 0 && (
      <>
        <div class="mt-4 text-center" id="pl-show-more-wrap">
          <button
            id="pl-show-more"
            class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-buff-border bg-buff-card px-6 py-3 text-sm font-bold text-buff-gold transition hover:border-buff-gold"
          >
            ⏷ Show More
          </button>
        </div>
        {total > initialShow + step && (
          <div class="mt-4 text-center" id="pl-view-all-wrap" style="display:none">
            <a
              href="/schedule"
              class="inline-flex items-center gap-2 rounded-lg border border-buff-gold bg-buff-gold px-6 py-3 text-sm font-bold text-black no-underline transition hover:opacity-90"
            >
              → Show all matches
            </a>
          </div>
        )}
      </>
    )}

    {viewAllMode === 'inline' && remaining > 0 && (
      <div class="mt-4 text-center" id="pl-show-all-wrap">
        <button
          id="pl-show-all"
          class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-buff-gold bg-buff-gold px-6 py-3 text-sm font-bold text-black transition hover:opacity-90"
        >
          Show {remaining} More Match{remaining !== 1 ? 'es' : ''}
        </button>
      </div>
    )}
  </section>
)}

<script>
  (function () {
    var grid = document.getElementById('popular-live-grid');
    if (!grid) return;

    var apiBase = grid.getAttribute('data-api');
    var items = [].slice.call(grid.querySelectorAll('[data-pl-index]'));
    if (items.length === 0) return;

    var hiddenClass = 'pl-hidden';
    var initialShow = 5;

    function hideAfter(n) {
      for (var i = 0; i < items.length; i++) {
        if (i < n) {
          items[i].classList.remove(hiddenClass);
        } else {
          items[i].classList.add(hiddenClass);
        }
      }
    }

    // Fetch viewer counts for all matches
    var promises = items.map(function (el) {
      var raw = el.getAttribute('data-sources');
      if (!raw) return Promise.resolve({ el: el, viewers: 0 });
      var sources;
      try { sources = JSON.parse(decodeURIComponent(raw)); } catch (e) { sources = []; }
      if (sources.length === 0) return Promise.resolve({ el: el, viewers: 0 });

      var sourcePromises = sources.map(function (s) {
        return fetch(apiBase + '/' + encodeURIComponent(s.source) + '/' + encodeURIComponent(s.id))
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var list = Array.isArray(data) ? data : [];
            var sum = 0;
            for (var k = 0; k < list.length; k++) sum += list[k].viewers || 0;
            return sum;
          })
          .catch(function () { return 0; });
      });

      return Promise.all(sourcePromises).then(function (sums) {
        var total = 0;
        for (var k = 0; k < sums.length; k++) total += sums[k];
        return { el: el, viewers: total };
      });
    });

    Promise.all(promises).then(function (results) {
      // Sort by viewers descending
      results.sort(function (a, b) { return b.viewers - a.viewers; });

      // Re-order DOM
      for (var i = 0; i < results.length; i++) {
        grid.appendChild(results[i].el);
      }

      // Update items reference
      items = results.map(function (r) { return r.el; });

      // Show first N, hide rest
      hideAfter(initialShow);

      // Update heading with live count
      var liveCount = 0;
      for (var i = 0; i < results.length; i++) {
        if (results[i].viewers > 0) liveCount++;
      }
      var heading = document.getElementById('pl-heading');
      if (heading) {
        heading.innerHTML = '<span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live" /> LIVE NOW' + (liveCount > 0 ? ' (' + liveCount + ' matches)' : '');
      }
    });

    // Show More / Show All buttons (work on current DOM order)
    var showMoreBtn = document.getElementById('pl-show-more');
    var showMoreWrap = document.getElementById('pl-show-more-wrap');
    var viewAllWrap = document.getElementById('pl-view-all-wrap');
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', function () {
        var hidden = grid.querySelectorAll('.' + hiddenClass);
        var step = parseInt(grid.getAttribute('data-pl-step')) || 5;
        var toShow = Math.min(hidden.length, step);
        for (var i = 0; i < toShow; i++) {
          hidden[i].classList.remove(hiddenClass);
        }
        if (showMoreWrap) showMoreWrap.style.display = 'none';
        var stillHidden = grid.querySelectorAll('.' + hiddenClass).length;
        if (stillHidden > 0 && viewAllWrap) {
          viewAllWrap.style.display = 'block';
        }
      });
    }

    var showAllBtn = document.getElementById('pl-show-all');
    var showAllWrap = document.getElementById('pl-show-all-wrap');
    if (showAllBtn) {
      showAllBtn.addEventListener('click', function () {
        var hidden = grid.querySelectorAll('.' + hiddenClass);
        for (var i = 0; i < hidden.length; i++) {
          hidden[i].classList.remove(hiddenClass);
        }
        if (showAllWrap) showAllWrap.style.display = 'none';
      });
    }
  })();
</script>

<style>
  .pl-hidden {
    display: none;
  }
</style>
