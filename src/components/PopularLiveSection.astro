---
export interface Props {
  sport?: string;
  initialShow?: number;
  step?: number;
  viewAllMode?: 'link' | 'inline';
}

const { sport = '', initialShow = 5, step = 5, viewAllMode = 'link' } = Astro.props;
---

<section id="popular-live-section" class="rounded-lg border border-buff-border bg-buff-darker p-2 sm:p-4">
  <h2 id="pl-heading" class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
    <span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live"></span>
    LIVE NOW
  </h2>

  <div id="popular-live-grid" class="divide-y divide-dashed divide-buff-border" data-pl-step={step} data-initial={initialShow} data-sport={sport}>
    <div class="flex animate-pulse items-center gap-2 bg-buff-card p-0 sm:gap-3 sm:p-3" data-pl-sk>
      <div class="flex min-w-0 flex-1 items-center gap-2">
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex flex-col items-center gap-1" style="min-width:80px">
        <div class="h-4 w-20 rounded bg-buff-border/30"></div>
        <div class="h-5 w-14 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
      </div>
      <div class="shrink-0 ml-1">
        <div class="h-4 w-4 rounded bg-buff-border/30"></div>
      </div>
    </div>
    <div class="flex animate-pulse items-center gap-2 bg-buff-card p-0 sm:gap-3 sm:p-3" data-pl-sk>
      <div class="flex min-w-0 flex-1 items-center gap-2">
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex flex-col items-center gap-1" style="min-width:80px">
        <div class="h-4 w-20 rounded bg-buff-border/30"></div>
        <div class="h-5 w-14 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
      </div>
      <div class="shrink-0 ml-1">
        <div class="h-4 w-4 rounded bg-buff-border/30"></div>
      </div>
    </div>
    <div class="flex animate-pulse items-center gap-2 bg-buff-card p-0 sm:gap-3 sm:p-3" data-pl-sk>
      <div class="flex min-w-0 flex-1 items-center gap-2">
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex flex-col items-center gap-1" style="min-width:80px">
        <div class="h-4 w-20 rounded bg-buff-border/30"></div>
        <div class="h-5 w-14 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
      </div>
      <div class="shrink-0 ml-1">
        <div class="h-4 w-4 rounded bg-buff-border/30"></div>
      </div>
    </div>
    <div class="flex animate-pulse items-center gap-2 bg-buff-card p-0 sm:gap-3 sm:p-3" data-pl-sk>
      <div class="flex min-w-0 flex-1 items-center gap-2">
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex flex-col items-center gap-1" style="min-width:80px">
        <div class="h-4 w-20 rounded bg-buff-border/30"></div>
        <div class="h-5 w-14 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
      </div>
      <div class="shrink-0 ml-1">
        <div class="h-4 w-4 rounded bg-buff-border/30"></div>
      </div>
    </div>
    <div class="flex animate-pulse items-center gap-2 bg-buff-card p-0 sm:gap-3 sm:p-3" data-pl-sk>
      <div class="flex min-w-0 flex-1 items-center gap-2">
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex flex-col items-center gap-1" style="min-width:80px">
        <div class="h-4 w-20 rounded bg-buff-border/30"></div>
        <div class="h-5 w-14 rounded bg-buff-border/30"></div>
      </div>
      <div class="flex min-w-0 flex-1 items-center justify-end gap-2">
        <div class="h-4 w-full max-w-32 rounded bg-buff-border/30"></div>
        <div class="h-8 w-8 shrink-0 rounded-full bg-buff-border/30"></div>
      </div>
      <div class="shrink-0 ml-1">
        <div class="h-4 w-4 rounded bg-buff-border/30"></div>
      </div>
    </div>
  </div>

  <div class="mt-4 text-center" id="pl-show-more-wrap">
    <button
      id="pl-show-more"
      class="inline-flex items-center justify-center gap-2 rounded-lg border-0 bg-buff-border/30 px-6 py-3 text-sm font-bold text-transparent animate-pulse"
    >
      ⏷ Show More
    </button>
  </div>

  {viewAllMode === 'link' && (
    <div class="mt-4 text-center" id="pl-view-all-wrap" style="display:none">
      <a
        id="pl-view-all-link"
        href="/schedule"
        class="inline-flex items-center gap-2 rounded-lg border border-buff-gold bg-buff-gold px-6 py-3 text-sm font-bold text-black no-underline transition hover:opacity-90"
      >
        → Show all matches
      </a>
    </div>
  )}
</section>

<script>
  (function () {
    var grid = document.getElementById('popular-live-grid');
    if (!grid) return;
    var section = document.getElementById('popular-live-section');
    var heading = document.getElementById('pl-heading');
    if (!heading) return;
    var showMoreBtn = document.getElementById('pl-show-more');
    var showMoreWrap = document.getElementById('pl-show-more-wrap');
    var viewAllLink = document.getElementById('pl-view-all-link');
    var viewAllWrap = document.getElementById('pl-view-all-wrap');

    var initialShow = parseInt(grid.getAttribute('data-initial')) || 5;
    var step = parseInt(grid.getAttribute('data-pl-step')) || 5;
    var sport = grid.getAttribute('data-sport') || '';

    var apiBase = 'https://stream.alphastreams.fit/api/live-now';
    var sepQ = sport ? '&' : '?';

    var TWENTY_FOUR_HOURS = 86400000;
    var THREE_HOURS = 3 * 60 * 60 * 1000;
    var TWENTY_FOUR_SEVEN_RE = /(24\/7|24 hour|247|always live)/i;

    function escapeHtml(text) {
      if (!text && text !== 0) return '';
      var d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    function formatET(date) {
      return new Date(date).toLocaleTimeString('en-US', {
        timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit', hour12: true,
      });
    }

    function formatDateShort(date) {
      return new Date(date).toLocaleDateString('en-US', {
        timeZone: 'America/New_York', month: 'short', day: 'numeric',
      });
    }

    function getDateStr(date) {
      return new Date(date).toLocaleDateString('en-US', { timeZone: 'America/New_York' });
    }

    function getStatus(date, viewers) {
      var now = Date.now();
      if (viewers > 0 || (now >= date && now <= date + 3 * 60 * 60 * 1000)) return 'live';
      if (now < date) return 'upcoming';
      return 'finished';
    }

    function makeBadge(category) {
      if (!category) return '';
      var names = {
        'american-football': 'NFL', basketball: 'NBA', baseball: 'MLB', hockey: 'NHL',
        fight: 'UFC', 'motor-sports': 'F1', football: 'Soccer', tennis: 'Tennis', golf: 'Golf',
      };
      var label = names[category] || category.charAt(0).toUpperCase() + category.slice(1);
      return '<span class="rounded bg-buff-border px-2 py-0.5 text-xs text-buff-muted">[' + escapeHtml(label) + ']</span>';
    }

    function buildCard(m) {
      var status = m._displayLive ? 'live' : getStatus(m.date, m.totalViewers);
      var home = m.teams && m.teams.home && m.teams.home.name ? m.teams.home : null;
      var away = m.teams && m.teams.away && m.teams.away.name ? m.teams.away : null;
      var homeName = home ? home.name : (m.title.split(' vs ')[0] || m.title);
      var awayName = away ? away.name : (m.title.split(' vs ')[1] || '');
      var homeBadge = home && home.badge ? home.badge : null;
      var awayBadge = away && away.badge ? away.badge : null;
      var badge = makeBadge(m.category);
      var now = Date.now();
      var isToday = getDateStr(m.date) === getDateStr(now);

      var centerHtml = '';
      if (status === 'live') {
        centerHtml = '<div class="flex flex-col items-center gap-1" style="min-width:80px">' +
          '<span class="flex items-center gap-1.5 text-xs font-bold text-buff-live">' +
          '<span class="inline-block h-2 w-2 rounded-full bg-buff-live animate-pulse-live"></span>' +
          '<span>' + (m.totalViewers > 0 ? m.totalViewers.toLocaleString() + ' watching' : 'LIVE') + '</span>' +
          '</span>' + badge + '</div>';
      } else if (status === 'upcoming') {
        centerHtml = '<div class="flex flex-col items-center gap-1" style="min-width:80px">' +
          (isToday
            ? '<span class="text-xs font-bold text-buff-gold">' + escapeHtml(formatET(m.date)) + '</span>'
            : '<span class="flex flex-col items-center font-mono text-xs text-buff-muted"><span>' + escapeHtml(formatDateShort(m.date)) + '</span><span>' + escapeHtml(formatET(m.date)) + '</span></span>'
          ) + badge + '</div>';
      } else {
        centerHtml = '<div class="flex flex-col items-center gap-1" style="min-width:80px">' +
          '<span class="rounded bg-buff-border px-2 py-0.5 text-xs font-bold text-buff-muted">FINAL</span>' +
          '<span class="whitespace-nowrap font-mono text-xs text-buff-muted">' + escapeHtml(formatET(m.date)) + ' ET</span>' +
          '</div>';
      }

      return '<a href="/match/' + encodeURIComponent(m.id) + '" class="relative flex items-center gap-2 bg-buff-card p-0 no-underline transition hover:bg-buff-hover sm:gap-3 sm:p-3" data-status="' + status + '">' +
        '<div class="flex min-w-0 flex-1 items-center gap-2">' +
        (homeBadge ? '<img src="/api/proxy/images/badge/' + homeBadge + '.webp" alt="" class="max-sm:hidden h-8 w-8 rounded-full object-contain" loading="lazy">' : '') +
        '<span class="truncate text-sm font-medium text-white">' + escapeHtml(homeName) + '</span>' +
        '</div>' +
        centerHtml +
        '<div class="flex min-w-0 flex-1 items-center justify-end gap-2">' +
        '<span class="truncate text-sm font-medium text-white">' + escapeHtml(awayName) + '</span>' +
        (awayBadge ? '<img src="/api/proxy/images/badge/' + awayBadge + '.webp" alt="" class="max-sm:hidden h-8 w-8 rounded-full object-contain" loading="lazy">' : '') +
        '</div>' +
        '<span class="ml-1 text-buff-muted">&rsaquo;</span>' +
        '</a>';
    }

    heading.innerHTML = '<span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live"></span> LIVE NOW <span class="text-sm font-normal text-buff-muted">Loading...</span>';

    function filter247(m) {
      if (!m.date || m.date <= 0) return false;
      if (Date.now() - m.date > TWENTY_FOUR_HOURS) return false;
      if (TWENTY_FOUR_SEVEN_RE.test(m.title)) return false;
      return true;
    }

    var sportParam = sport ? '?sport=' + sport : '';
    var todayUrl = apiBase + sportParam + sepQ + 'scope=all-today';
    var popularUrl = apiBase + sportParam + sepQ + 'scope=live-popular';
    var liveUrl = apiBase + sportParam + sepQ + 'scope=live';

    Promise.all([fetch(todayUrl), fetch(popularUrl), fetch(liveUrl)])
      .then(function (responses) {
        return Promise.all(responses.map(function (r) { return r.json(); }));
      })
      .then(function (results) {
        var todayData = Array.isArray(results[0]) ? results[0] : [];
        var popularData = Array.isArray(results[1]) ? results[1] : [];
        var liveData = Array.isArray(results[2]) ? results[2] : [];

        todayData = todayData.filter(filter247);
        popularData = popularData.filter(filter247);
        liveData = liveData.filter(filter247);

        // Tier 1: from today, viewers > 0 && date <= now + 3h
        var tier1Ids = {};
        var tier1 = [];
        var now = Date.now();
        for (var i = 0; i < todayData.length; i++) {
          var m = todayData[i];
          if (m.totalViewers > 0 && m.date <= now + THREE_HOURS) {
            tier1Ids[m.id] = true;
            tier1.push(m);
          }
        }
        tier1.sort(function (a, b) { return (b.totalViewers || 0) - (a.totalViewers || 0); });

        // Tier 2: from live/popular, exclude already in Tier 1
        var tier2Ids = {};
        var tier2 = [];
        for (var i = 0; i < popularData.length; i++) {
          var m = popularData[i];
          if (tier1Ids[m.id]) continue;
          tier2Ids[m.id] = true;
          m._displayLive = true;
          tier2.push(m);
        }
        tier2.sort(function (a, b) { return a.date - b.date; });

        // Tier 3: from live, exclude already in Tier 1 or Tier 2
        var tier3 = [];
        for (var i = 0; i < liveData.length; i++) {
          var m = liveData[i];
          if (tier1Ids[m.id]) continue;
          if (tier2Ids[m.id]) continue;
          m._displayLive = true;
          tier3.push(m);
        }
        tier3.sort(function (a, b) { return a.date - b.date; });

        var liveMatches = tier1.concat(tier2).concat(tier3);

        if (liveMatches.length === 0) {
          section.style.display = 'none';
          return;
        }

        var liveCount = liveMatches.length;
        heading.innerHTML = '<span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live"></span> LIVE NOW' + (liveCount > 0 ? ' (' + liveCount + ')' : '');

        // Build real cards
        var cardEls = liveMatches.map(function (m) {
          var div = document.createElement('div');
          div.innerHTML = buildCard(m);
          return div.firstChild;
        });

        // Replace grid contents
        grid.innerHTML = '';
        for (var i = 0; i < cardEls.length; i++) {
          grid.appendChild(cardEls[i]);
        }

        var show = Math.min(cardEls.length, initialShow);
        for (var i = 0; i < cardEls.length; i++) {
          cardEls[i].style.display = i < show ? '' : 'none';
        }

        var hiddenCount = cardEls.length - show;

        // Swap button to real styling if needed
        if (hiddenCount > 0 && showMoreBtn) {
          showMoreBtn.className = 'inline-flex cursor-pointer items-center gap-2 rounded-lg border border-buff-border bg-buff-card px-6 py-3 text-sm font-bold text-buff-gold transition hover:border-buff-gold';
          showMoreBtn.addEventListener('click', function () {
            var hidden = [];
            for (var i = 0; i < cardEls.length; i++) {
              if (cardEls[i].style.display === 'none') hidden.push(cardEls[i]);
            }
            var toShow = Math.min(hidden.length, step);
            for (var i = 0; i < toShow; i++) {
              hidden[i].style.display = '';
            }
            var still = hidden.length - toShow;
            showMoreBtn.style.display = 'none';
            if (still > 0 && viewAllLink && viewAllWrap) {
              viewAllWrap.style.display = 'block';
            }
          });
        } else if (showMoreBtn) {
          showMoreBtn.style.display = 'none';
        }
      })
      .catch(function () {
        section.style.display = 'none';
      });
  })();
</script>