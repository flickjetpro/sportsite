---
import type { PremiumMatch } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  allMatches: PremiumMatch[];
}

const { allMatches } = Astro.props;
const now = Date.now();
const liveMatches = allMatches.filter((m) => {
  return m.popular && now >= m.date && now <= m.date + 3 * 60 * 60 * 1000;
});
const INITIAL_SHOW = 5;
const hasMore = liveMatches.length > INITIAL_SHOW;
---

{liveMatches.length > 0 && (
  <section>
    <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
      <span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live" />
      POPULAR LIVE
    </h2>
    <div class="flex flex-col gap-2" id="popular-live-grid">
      {liveMatches.map((m, i) => (
        <div class={i >= INITIAL_SHOW ? 'hidden-extra' : ''} data-pl-index={i}>
          <div class="flex items-start gap-2">
            <div class="min-w-0 flex-1">
              <MatchCard match={m} showCategoryBadge={true} />
            </div>
            <span class="mt-3 flex shrink-0 items-center gap-1 rounded bg-buff-dark px-2 py-1 text-xs font-bold text-buff-gold">
              ★ Popular
            </span>
          </div>
        </div>
      ))}
    </div>

    {hasMore && (
      <div class="mt-4 text-center" id="show-more-wrap">
        <button
          id="show-more-btn"
          class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-buff-border bg-buff-card px-6 py-3 text-sm font-bold text-buff-gold transition hover:border-buff-gold"
        >
          ⏷ Show More ({liveMatches.length - INITIAL_SHOW})
        </button>
      </div>
    )}

    <div class="mt-4 text-center" id="view-all-wrap" style="display:none">
      <a
        href="/schedule"
        class="inline-flex items-center gap-2 rounded-lg border border-buff-gold bg-buff-gold px-6 py-3 text-sm font-bold text-black no-underline transition hover:opacity-90"
      >
        → View All Live Matches
      </a>
    </div>
  </section>
)}

<script>
  (function () {
    var grid = document.getElementById('popular-live-grid');
    var showMoreBtn = document.getElementById('show-more-btn');
    var showMoreWrap = document.getElementById('show-more-wrap');
    var viewAllWrap = document.getElementById('view-all-wrap');
    if (!grid || !showMoreBtn) return;

    showMoreBtn.addEventListener('click', function () {
      var items = grid.querySelectorAll('.hidden-extra');
      for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('hidden-extra');
      }
      if (showMoreWrap) showMoreWrap.style.display = 'none';
      if (viewAllWrap) viewAllWrap.style.display = 'block';
    });
  })();
</script>

<style>
  .hidden-extra {
    display: none;
  }
</style>
