---
import type { PremiumMatch } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  allMatches: PremiumMatch[];
  initialShow: number;
  step: number;
  viewAllMode: 'link' | 'inline';
}

const { allMatches, initialShow, step, viewAllMode } = Astro.props;

const byViewers = allMatches.filter((m) => (m.totalViewers ?? 0) > 0).sort((a, b) => (b.totalViewers ?? 0) - (a.totalViewers ?? 0));
const viewerIds = new Set(byViewers.map((m) => m.id));
const livePopular = allMatches.filter((m) => !viewerIds.has(m.id) && m._liveSource && m.popular);
const liveRest = allMatches.filter((m) => !viewerIds.has(m.id) && m._liveSource && !m.popular);
const ordered = [...byViewers, ...livePopular, ...liveRest];
const total = ordered.length;
const remaining = total - initialShow;
---

{total > 0 && (
  <section class="rounded-lg border border-buff-border bg-buff-darker p-4">
    <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
      <span class="inline-block h-3 w-3 rounded-full bg-buff-live animate-pulse-live" />
      LIVE NOW
    </h2>

    <div class="flex flex-col divide-y divide-dashed divide-buff-border" id="popular-live-grid" data-pl-step={step}>
      {ordered.map((m, i) => (
        <div class={i >= initialShow ? 'pl-hidden' : ''} data-pl-index={i}>
          <MatchCard match={m} showCategoryBadge={true} />
        </div>
      ))}
    </div>

    {viewAllMode === 'link' && remaining > 0 && (
      <>
        <div class="mt-4 text-center" id="pl-show-more-wrap">
          <button
            id="pl-show-more"
            class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-buff-border bg-buff-card px-6 py-3 text-sm font-bold text-buff-gold transition hover:border-buff-gold"
          >
            ⏷ Show More
          </button>
        </div>
        {total > initialShow + step && (
          <div class="mt-4 text-center" id="pl-view-all-wrap" style="display:none">
            <a
              href="/schedule"
              class="inline-flex items-center gap-2 rounded-lg border border-buff-gold bg-buff-gold px-6 py-3 text-sm font-bold text-black no-underline transition hover:opacity-90"
            >
              → Show all live matches
            </a>
          </div>
        )}
      </>
    )}

    {viewAllMode === 'inline' && remaining > 0 && (
      <div class="mt-4 text-center" id="pl-show-all-wrap">
        <button
          id="pl-show-all"
          class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-buff-gold bg-buff-gold px-6 py-3 text-sm font-bold text-black transition hover:opacity-90"
        >
          Show {remaining} More Live Match{remaining !== 1 ? 'es' : ''}
        </button>
      </div>
    )}
  </section>
)}

<script>
  (function () {
    var grid = document.getElementById('popular-live-grid');
    if (!grid) return;

    // Link mode: Show More (step) → Show all live matches link
    var showMoreBtn = document.getElementById('pl-show-more');
    var showMoreWrap = document.getElementById('pl-show-more-wrap');
    var viewAllWrap = document.getElementById('pl-view-all-wrap');
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', function () {
        var hidden = grid.querySelectorAll('.pl-hidden');
        var step = parseInt(grid.getAttribute('data-pl-step')) || 5;
        var toShow = Math.min(hidden.length, step);
        for (var i = 0; i < toShow; i++) {
          hidden[i].classList.remove('pl-hidden');
        }
        if (showMoreWrap) showMoreWrap.style.display = 'none';
        var stillHidden = grid.querySelectorAll('.pl-hidden').length;
        if (stillHidden > 0 && viewAllWrap) {
          viewAllWrap.style.display = 'block';
        }
      });
    }

    // Inline mode: Show All remaining
    var showAllBtn = document.getElementById('pl-show-all');
    var showAllWrap = document.getElementById('pl-show-all-wrap');
    if (showAllBtn) {
      showAllBtn.addEventListener('click', function () {
        var hidden = grid.querySelectorAll('.pl-hidden');
        for (var i = 0; i < hidden.length; i++) {
          hidden[i].classList.remove('pl-hidden');
        }
        if (showAllWrap) showAllWrap.style.display = 'none';
      });
    }
  })();
</script>

<style>
  .pl-hidden {
    display: none;
  }
</style>
