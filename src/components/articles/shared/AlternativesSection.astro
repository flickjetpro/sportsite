---
export interface Props {
  displayName: string;
  intro?: string;
}

const { displayName, intro } = Astro.props;
---

<section class="not-prose mt-12">
  <h2 class="mb-2 text-2xl font-bold text-white">Best Buffstreams Alternatives for {displayName} in 2026</h2>
  {
    intro ? (
      <p class="mb-6 text-sm text-buff-muted">{intro}</p>
    ) : (
      <p class="mb-6 text-sm text-buff-muted">Need a backup option or additional variety for {displayName} streaming? These trusted free sports platforms deliver excellent coverage across the same leagues and events.</p>
    )
  }

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">⚡</span>
      <div>
        <h3 class="text-base font-bold text-white">Crackstreams</h3>
        <p class="text-xs text-buff-muted">Multi-Sport Streaming Hub · Free</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">Crackstreams delivers free HD live sports streams for all major leagues and events. Users can watch NFL football, NBA basketball, MLB baseball, NHL hockey, Premier League, Champions League, La Liga, Serie A, UFC, MMA fights, boxing, Formula 1, WWE, and international soccer live with zero registration or payments. Multiple high-quality backup streams ensure reliable performance on any device.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">📡</span>
      <div>
        <h3 class="text-base font-bold text-white">Sportsurge</h3>
        <p class="text-xs text-buff-muted">Live Streams Hub · Multi-Sport Aggregator</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">Sportsurge offers free HD live sports streams for all major leagues and events. Users can stream NFL football, NBA basketball, MLB baseball, NHL hockey, Premier League, Champions League, Bundesliga, Serie A, UFC, MMA, boxing, Formula 1, WWE, and international soccer live with zero registration or subscriptions required.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">📺</span>
      <div>
        <h3 class="text-base font-bold text-white">StreamEast</h3>
        <p class="text-xs text-buff-muted">Free Sports Streaming Platform</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">StreamEast is a popular free sports streaming platform covering NFL, NBA, NHL, MLB, UFC, soccer, F1, and more. The platform provides HD quality streams with multiple backup links for every major event. No sign-up is required and the site is optimized for mobile viewing.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">🔥</span>
      <div>
        <h3 class="text-base font-bold text-white">Methstreams</h3>
        <p class="text-xs text-buff-muted">Multi-Sport Free Streaming</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">Methstreams provides free HD live sports streams for NFL, NBA, MLB, NHL, UFC, MMA, boxing, WWE, and soccer leagues worldwide. The platform offers multiple working backup links with instant playback and is accessible on mobile, tablet, and desktop devices without any registration.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">🌐</span>
      <div>
        <h3 class="text-base font-bold text-white">Totalsportek</h3>
        <p class="text-xs text-buff-muted">Sports Streaming Directory</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">Totalsportek offers free HD live sports streams for NFL football, NBA basketball, MLB baseball, NHL hockey, Premier League, Champions League, Bundesliga, UFC, MMA, boxing, Formula 1, WWE, and international soccer. Multiple working backup streams with smooth performance on mobile, tablet, and desktop.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">⚽</span>
      <div>
        <h3 class="text-base font-bold text-white">FootyBite</h3>
        <p class="text-xs text-buff-muted">Football & Multi-Sport Streaming</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">FootyBite delivers free HD live sports streams with a strong focus on football including Premier League, Champions League, La Liga, Serie A, Bundesliga, EFL Championship, and international matches. NFL, NBA, UFC, MMA, boxing, F1, and WWE coverage is also available with multiple reliable backup streams.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">📺</span>
      <div>
        <h3 class="text-base font-bold text-white">TheStreamEast</h3>
        <p class="text-xs text-buff-muted">Live Sports Streaming Platform</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">TheStreamEast provides access to free sports streaming for NFL, NBA, UFC, soccer, boxing, and F1 directly through any mobile browser on any device. HD quality streams with instant play and multiple links make it an easy alternative for live sports.</p>
  </div>

  <div class="mb-5 rounded-lg border border-buff-border bg-buff-darker p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="text-2xl">📡</span>
      <div>
        <h3 class="text-base font-bold text-white">SportSurge</h3>
        <p class="text-xs text-buff-muted">Community Stream Aggregator</p>
      </div>
    </div>
    <p class="text-sm text-buff-muted">SportSurge aggregates free live sports streams from across the internet for NFL, NBA, MLB, NHL, UFC, soccer, F1, and more backed by an active community that shares and validates working links. The platform covers all major leagues with multiple stream options for every event.</p>
  </div>
</section>
