<script>
  function updateMatchTimers() {
    document.querySelectorAll('[data-status]').forEach((card) => {
      const status = card.getAttribute('data-status');
      const matchDate = Number(card.getAttribute('data-date'));
      const timer = card.querySelector('.mc-timer');
      if (!timer) return;

      if (status === 'live') {
        const mins = Math.floor((Date.now() - matchDate) / 60000);
        if (mins < 1) { timer.textContent = 'now'; return; }
        if (mins < 60) { timer.textContent = mins + 'm'; return; }
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        if (h < 2) { timer.textContent = h + 'h ' + m + 'm'; return; }
        timer.textContent = h + '.' + Math.floor(m / 6) + 'h';
      }

      if (status === 'upcoming') {
        const diff = matchDate - Date.now();
        if (diff <= 0) { timer.textContent = 'LIVE'; return; }
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        timer.textContent = (h > 0 ? h + 'h ' + m + 'm ' : m + 'm ') + s + 's';
      }
    });
  }

  updateMatchTimers();
  setInterval(updateMatchTimers, 1000);
</script>
