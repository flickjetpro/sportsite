---
export interface Props {
  matchDate: number;
  sport?: string;
}
const { matchDate } = Astro.props;
---

<div id="countdown" class="font-mono text-lg text-buff-gold" data-target={matchDate}>
  <span id="cd-text">--</span>
</div>

<script is:inline>
  (function () {
    var el = document.getElementById('countdown');
    if (!el) return;
    var target = Number(el.getAttribute('data-target'));
    if (!target) return;
    var textEl = document.getElementById('cd-text');
    if (!textEl) return;

    function tick() {
      var diff = target - Date.now();
      if (diff <= 0) {
        textEl.textContent = 'LIVE';
        return;
      }
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      textEl.textContent = 'Starts in ' + h + 'h ' + m + 'm ' + s + 's';
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>
