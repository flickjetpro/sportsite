---
const { currentSport } = Astro.props as { currentSport?: string };
---

<header class="bg-buff-darker">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href="/" class="text-2xl font-bold tracking-tight text-buff-gold no-underline">
      Buffstreams Backup
    </a>
    <button id="hamburger" class="flex cursor-pointer items-center justify-center sm:hidden" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <nav id="nav-menu" class="hidden gap-1 sm:flex">
      {['nfl', 'mlb', 'nba', 'nhl', 'ufc', 'f1', 'soccer', 'tennis', 'golf'].map(
        (sport) => {
          const label = sport === 'ufc' ? 'UFC' : sport === 'f1' ? 'F1' : sport.charAt(0).toUpperCase() + sport.slice(1);
          return (
            <a
              href={`/${sport}`}
              class={`whitespace-nowrap rounded px-3 py-1.5 text-sm no-underline transition-colors ${
                currentSport === sport
                  ? 'text-buff-live font-bold'
                  : 'text-white hover:text-buff-live'
              }`}
            >
              {label}
            </a>
          );
        }
      )}
    </nav>
  </div>
  <div id="mobile-menu" class="hidden border-t border-buff-border bg-buff-dark px-4 py-2 sm:hidden">
    <div class="flex flex-col gap-1">
      {['nfl', 'mlb', 'nba', 'nhl', 'ufc', 'f1', 'soccer', 'tennis', 'golf'].map(
        (sport) => {
          const label = sport === 'ufc' ? 'UFC' : sport === 'f1' ? 'F1' : sport.charAt(0).toUpperCase() + sport.slice(1);
          return (
            <a
              href={`/${sport}`}
              class={`block rounded px-3 py-2 text-sm no-underline transition-colors ${
                currentSport === sport
                  ? 'text-buff-live font-bold'
                  : 'text-white hover:text-buff-live'
              }`}
            >
              {label}
            </a>
          );
        }
      )}
    </div>
  </div>
</header>

<script>
  (function () {
    var btn = document.getElementById('hamburger');
    var mobileMenu = document.getElementById('mobile-menu');
    if (btn && mobileMenu) {
      btn.addEventListener('click', function () {
        mobileMenu.classList.toggle('hidden');
      });
    }
  })();
</script>
