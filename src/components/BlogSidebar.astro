---
import { blogPosts } from '../data/blog-posts';

export interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
const posts = currentSlug ? blogPosts.filter((p) => p.slug !== currentSlug) : blogPosts;
---

<div class="rounded-lg border border-buff-border bg-buff-darker p-4">
  <h3 class="mb-3 text-sm font-bold text-white">Blog</h3>
  <div class="flex flex-col gap-3">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="group block no-underline">
        <img src={post.image} alt={post.title} class="mb-1 w-full rounded object-cover" loading="lazy" />
        <h4 class="text-xs font-medium text-white group-hover:text-buff-live">{post.title}</h4>
      </a>
    ))}
  </div>
</div>
