---
const allSports = [
  { id: 'nfl', label: 'NFL' },
  { id: 'ncaaf', label: 'NCAAF' },
  { id: 'mlb', label: 'MLB' },
  { id: 'nba', label: 'NBA' },
  { id: 'ncaab', label: 'NCAAB' },
  { id: 'wnba', label: 'WNBA' },
  { id: 'nhl', label: 'NHL' },
  { id: 'ufc', label: 'UFC' },
  { id: 'boxing', label: 'Boxing' },
  { id: 'wwe', label: 'WWE' },
  { id: 'mma', label: 'MMA' },
  { id: 'f1', label: 'F1' },
  { id: 'mls', label: 'MLS' },
  { id: 'tennis', label: 'Tennis' },
  { id: 'nascar', label: 'NASCAR' },
  { id: 'indycar', label: 'IndyCar' },
  { id: 'soccer', label: 'Soccer' },
  { id: 'golf', label: 'Golf' },
];
---

<section class="border-t border-buff-border bg-buff-darker px-4 py-10">
  <div class="mx-auto max-w-7xl">
    <h2 class="mb-6 text-center text-lg font-semibold text-buff-gold">Sports Categories</h2>
    <div class="flex flex-wrap justify-center gap-3">
      {allSports.map((s) => (
        <a
          href={`/${s.id}`}
          class="inline-block rounded-full border border-buff-border bg-buff-dark px-5 py-2 text-sm font-medium text-white no-underline transition-colors hover:border-buff-gold hover:text-buff-gold"
        >
          {s.label}
        </a>
      ))}
    </div>
  </div>
</section>
