---
export interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-4 text-sm text-buff-muted">
  {items.map((item, i) => (
    <span>
      {i > 0 && <span class="mx-1">›</span>}
      {i < items.length - 1 ? (
        <a href={item.url} class="text-buff-gold no-underline hover:underline">
          {item.name}
        </a>
      ) : (
        <span class="text-white">{item.name}</span>
      )}
    </span>
  ))}
</nav>
