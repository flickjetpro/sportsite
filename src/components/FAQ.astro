---
const faqs = [
  {
    question: 'What is Buffstreams Backup?',
    answer: 'Buffstreams Backup is a sports schedule directory that provides game times, match information, and sports calendar data for NFL, NBA, MLB, NHL, UFC, and other major sports leagues.',
  },
  {
    question: 'How do I find game schedules?',
    answer: 'Use the sport navigation tabs at the top of the page to browse schedules by league, or use the calendar to navigate to a specific date. Each match page shows full details and available stream sources.',
  },
  {
    question: 'Is this site affiliated with the NFL/NBA/MLB?',
    answer: 'No. Buffstreams Backup is an independent sports schedule directory. We are not affiliated with, endorsed by, or connected to any professional sports league or organization.',
  },
  {
    question: 'Do you host video streams?',
    answer: 'No. We do not host, stream, embed, or link to any video or audio content. We provide schedule information only. Stream source links are provided by third-party services.',
  },
  {
    question: 'How often is the schedule updated?',
    answer: 'The schedule is automatically refreshed every 30 minutes to ensure you have the most up-to-date game times and match information.',
  },
];
---

<section>
  <h2 class="mb-4 text-lg font-bold text-white">Frequently Asked Questions</h2>
  <div class="flex flex-col gap-3">
    {faqs.map((faq) => (
      <details class="rounded-lg border border-buff-border bg-buff-card">
        <summary class="cursor-pointer px-4 py-3 font-medium text-white">
          {faq.question}
        </summary>
        <p class="border-t border-buff-border px-4 py-3 text-sm text-buff-muted">
          {faq.answer}
        </p>
      </details>
    ))}
  </div>
</section>
