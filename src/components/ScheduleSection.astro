---
import type { PremiumMatch } from '../lib/api';
import { groupBySport } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  matches: PremiumMatch[];
}

const { matches } = Astro.props;
const grouped = groupBySport(matches);
const premiumOrder = ['NFL', 'NBA', 'MLB', 'NHL', 'UFC', 'F1', 'Soccer', 'Tennis', 'Golf'];
---

{matches.length > 0 && (
  <section>
    <h2 class="mb-4 text-lg font-bold text-white">TODAY'S SCHEDULE</h2>
    <div class="flex flex-col gap-6">
      {[...grouped.entries()]
        .sort(([a], [b]) => {
          const ai = premiumOrder.indexOf(a);
          const bi = premiumOrder.indexOf(b);
          return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
        })
        .map(([sport, sportMatches]) => (
          <div>
            <h3 class="mb-2 text-sm font-semibold uppercase tracking-wider text-buff-gold">
              {sport}
              <span class="text-buff-muted"> ({sportMatches.length})</span>
            </h3>
            <div class="flex flex-col gap-2">
              {sportMatches.map((m) => (
                <MatchCard match={m} />
              ))}
            </div>
          </div>
        ))}
    </div>
  </section>
)}
