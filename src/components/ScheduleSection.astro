---
import type { PremiumMatch } from '../lib/api';
import { groupBySport } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  matches: PremiumMatch[];
  heading?: string;
  sportsWithFuture?: Set<string>;
}

const { matches, heading = "SCHEDULE", sportsWithFuture } = Astro.props;
const premiumMatches = matches.filter((m) => m.premiumSport !== null);
const grouped = groupBySport(premiumMatches);
const premiumOrder = ['NFL', 'NBA', 'MLB', 'NHL', 'UFC', 'F1', 'Soccer', 'Tennis', 'Golf'];
---

{matches.length > 0 && (
  <section>
    <h2 class="mb-4 text-lg font-bold text-white">{heading}</h2>
    <div class="flex flex-col gap-6">
      {[...grouped.entries()]
        .sort(([a], [b]) => {
          const ai = premiumOrder.indexOf(a);
          const bi = premiumOrder.indexOf(b);
          return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
        })
        .map(([sport, sportMatches]) => (
          <div>
            <h3 class="mb-2 flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-buff-gold">
              <span>{sport}</span>
              <span class="text-buff-muted">({sportMatches.length})</span>
              {sportsWithFuture?.has(sport) && (
                <a href="/schedule" class="ml-auto text-[10px] font-normal text-buff-gold no-underline hover:underline">
                  Show more →
                </a>
              )}
            </h3>
            <div class="flex flex-col gap-2">
              {sportMatches
                .sort((a, b) => (b.popular ? 1 : 0) - (a.popular ? 1 : 0))
                .map((m) => (
                  <MatchCard match={m} />
                ))}
            </div>
          </div>
        ))}
    </div>
  </section>
)}
