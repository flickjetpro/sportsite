---
import type { PremiumMatch } from '../lib/api';
import { groupBySport } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  matches: PremiumMatch[];
  heading?: string;
  sportsWithFuture?: Set<string>;
}

const { matches, heading = "STREAM LINKS", sportsWithFuture } = Astro.props;
const headingPrefix = heading.replace(/ STREAM LINKS$/i, '');
const premiumMatches = matches.filter((m) => m.premiumSport !== null);
const grouped = groupBySport(premiumMatches);
const premiumOrder = ['NFL', 'NBA', 'MLB', 'NHL', 'UFC', 'F1', 'Soccer', 'Tennis', 'Golf'];
const sportIcons: Record<string, string> = {
  'NFL': '/images/nfl.webp',
  'NBA': '/images/nba.webp',
  'MLB': '/images/mlb.webp',
  'NHL': '/images/nhl.webp',
  'UFC': '/images/ufc.webp',
  'F1': '/images/f1.webp',
  'Soccer': '/images/soccer.webp',
};
---

{premiumMatches.length > 0 && (
  <div class="flex flex-col gap-8">
    {[...grouped.entries()]
      .sort(([a], [b]) => {
        const ai = premiumOrder.indexOf(a);
        const bi = premiumOrder.indexOf(b);
        return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
      })
      .map(([sport, sportMatches]) => (
        <section class="rounded-lg border border-buff-border bg-buff-darker p-4">
          <div class="mb-3 flex items-center gap-2">
            {sportIcons[sport] && (
              <img width="24" height="24" src={sportIcons[sport]} alt={sport} class="rounded-full object-contain" />
            )}
            <h2 class="text-base font-bold text-white">
              {headingPrefix ? `${headingPrefix} ` : ''}{sport} STREAM LINKS
              <span class="font-normal text-buff-muted"> ({sportMatches.length})</span>
            </h2>
          </div>
          <div class="flex flex-col divide-y divide-dotted divide-[#eee]">
            {sportMatches
              .sort((a, b) => (b.popular ? 1 : 0) - (a.popular ? 1 : 0))
              .map((m) => (
                <MatchCard match={m} />
              ))}
          </div>
          {sportsWithFuture?.has(sport) && (
            <div class="mt-2 text-right">
              <a href={"/" + sport.toLowerCase()} class="text-xs text-buff-gold no-underline hover:underline">
                Show more →
              </a>
            </div>
          )}
        </section>
      ))}
  </div>
)}
