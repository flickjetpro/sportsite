---
import type { PremiumMatch } from '../lib/api';
import MatchCard from './MatchCard.astro';

export interface Props {
  matches: PremiumMatch[];
}

const { matches } = Astro.props;
const otherMatches = matches.filter((m) => m.premiumSport === null);
---

{otherMatches.length > 0 && (
  <section>
    <h2 class="mb-3 text-lg font-bold text-white">OTHER MATCHES</h2>
    <div class="flex flex-col divide-y divide-dashed divide-[#eee]">
      {otherMatches.map((m) => (
        <MatchCard match={m} showCategoryBadge={true} />
      ))}
    </div>
  </section>
)}
