---
import datesData from '../data/dates.json';

export interface Props {
  sport?: string;
}

const { sport } = Astro.props;
const matchDates = new Set(datesData as string[]);

const now = new Date();
const todayStr = now.toISOString().split('T')[0];
const currentMonth = now.getMonth();
const currentYear = now.getFullYear();

const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

interface DayCell {
  day: number;
  hasMatch: boolean;
  dateStr: string;
  isToday: boolean;
  isNextMonth: boolean;
}

const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
const firstDay = new Date(currentYear, currentMonth, 1).getDay();

// Determine next month/year
let nextMonth = currentMonth + 1;
let nextYear = currentYear;
if (nextMonth > 11) {
  nextMonth = 0;
  nextYear++;
}

const days: DayCell[] = [];

// Current month days
for (let d = 1; d <= daysInMonth; d++) {
  const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  days.push({
    day: d,
    hasMatch: matchDates.has(dateStr),
    dateStr,
    isToday: dateStr === todayStr,
    isNextMonth: false,
  });
}

// Next month overflow — show next-month days that have matches (consecutive from day 1)
for (let d = 1; ; d++) {
  const dateStr = `${nextYear}-${String(nextMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  if (!matchDates.has(dateStr)) break;
  days.push({
    day: d,
    hasMatch: true,
    dateStr,
    isToday: false,
    isNextMonth: true,
  });
}
---

<div class="rounded-lg border border-buff-border bg-buff-card p-4">
  <div class="mb-3 flex items-center justify-between">
    <h3 class="text-sm font-bold text-white">{monthNames[currentMonth]} {currentYear}</h3>
  </div>
  <div class="grid grid-cols-7 gap-1 text-center">
    {dayNames.map((dn) => (
      <div class="py-1 text-xs font-medium text-buff-muted">{dn}</div>
    ))}
    {Array.from({ length: firstDay }).map(() => (
      <div />
    ))}
    {days.map((d) => (
      d.hasMatch ? (
        <a
            href={`/schedule/${d.dateStr}`}
          class={`relative rounded py-1.5 text-sm no-underline transition ${
            d.isNextMonth ? 'opacity-60 text-buff-muted hover:bg-buff-border' : d.isToday
              ? 'bg-buff-gold font-bold text-black'
              : 'text-white hover:bg-buff-border'
          }`}
        >
          {d.day}
          {d.hasMatch && !d.isToday && (
            <span class="absolute -bottom-0.5 left-1/2 h-1 w-1 -translate-x-1/2 rounded-full bg-buff-gold" />
          )}
        </a>
      ) : (
        <div class={`rounded py-1.5 text-sm ${d.isNextMonth ? 'opacity-40 text-buff-muted' : d.isToday ? 'bg-buff-border font-bold text-white' : 'text-buff-muted'}`}>
          {d.day}
        </div>
      )
    ))}
  </div>
</div>
