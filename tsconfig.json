{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		}
	},
	"include": [
		"src/**/*",
		"scripts/**/*",
		"worker/**/*",
		"./worker-configuration.d.ts"
	]
}